                      "Singapore",
                      "Australia",
                      "Malaysia",
                      "Dubai"
                    ],
                    "expectedEmploymentTypes": [
                      "REMOTE_FULL_TIME",
                      "REMOTE_PART_TIME"
                    ],
                    "preferredTimezone": "GMT+7"
                  },
                  "careerGoals": [
                    "Become a Fullstack AI Engineer building impactful AI products.",
                    "Work on modern AI technologies and keep up with industry trends.",
                    "Find a remote-first company with flexible working hours.",
