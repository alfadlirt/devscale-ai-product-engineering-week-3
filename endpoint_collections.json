  "paths": {
    "/curiculum-vitae": {
      "get": {
        "summary": "Get CV",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "operationId": "Get_CV"
      },
      "post": {
        "summary": "Upload CV",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "operationId": "Upload_CV",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "example": "cv-1"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/job-analyzer": {
      "get": {
        "summary": "Get Job Analyze",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "operationId": "Get_Job_Analyze"
      }
    },
    "/job-analyzer/by-job-posting": {
      "post": {
        "summary": "Analyze Job Posting",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "operationId": "Analyze_Job_Posting",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "jobPostingUrls": [
                  "https://remoteok.com/remote-jobs/remote-senior-ai-engineer-architect-lemon-io-1134396",
                  "https://remoteok.com/remote-jobs/remote-senior-software-engineer-stellar-ai-1128869"
                ],
                "cvId": 1,
                "userContext": {
